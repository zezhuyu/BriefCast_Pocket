BRIEFCAST_API_PORT=5002

# AI provider selection for transcript generation:
# openai-compatible | anthropic | codex-cli | claude-cli
BRIEFCAST_ACTIVE_PROVIDER=codex-cli

# OpenAI-compatible provider
BRIEFCAST_OPENAI_BASE_URL=https://api.openai.com/v1
BRIEFCAST_OPENAI_API_KEY=
BRIEFCAST_OPENAI_MODEL=gpt-4.1-mini
BRIEFCAST_OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic provider
BRIEFCAST_ANTHROPIC_API_KEY=
BRIEFCAST_ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Codex CLI provider
BRIEFCAST_CODEX_COMMAND=codex
BRIEFCAST_CODEX_ARGS_TEMPLATE=exec {prompt}

# Claude CLI provider
BRIEFCAST_CLAUDE_COMMAND=claude
BRIEFCAST_CLAUDE_ARGS_TEMPLATE=-p {prompt}

# TTS selection:
# openai-compatible | system-say
BRIEFCAST_TTS_PROVIDER=openai-compatible
BRIEFCAST_TTS_VOICE=alloy
BRIEFCAST_TTS_MODEL=gpt-4o-mini-tts
BRIEFCAST_TTS_SYSTEM_VOICE=Samantha
