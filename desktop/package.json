{
  "name": "briefcast-desktop-ts",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript desktop rewrite for BriefCast",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"tsup src/main/main.ts src/main/preload.ts --format cjs --external electron --out-dir dist-electron --watch\" \"npm --prefix ./frontend run dev\" \"wait-on dist-electron/main.cjs dist-electron/preload.cjs http-get://127.0.0.1:3000 && cross-env FRONTEND_DEV_SERVER_URL=http://127.0.0.1:3000 BRIEFCAST_ENABLE_API_BRIDGE=1 electronmon dist-electron/main.cjs\"",
    "build": "tsup src/main/main.ts src/main/preload.ts --format cjs --external electron --out-dir dist-electron && cross-env EXPORT_MODE=true npm --prefix ./frontend run build",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:dmg": "npm run build && electron-builder --mac dmg",
    "dist:dmg:unsigned": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-rebuild"
  },
  "build": {
    "appId": "com.briefcast.desktopts",
    "productName": "BriefCast",
    "icon": "./assets/app-icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "frontend/out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      },
      {
        "from": "assets/image",
        "to": "assets/image"
      },
      {
        "from": "assets/audio",
        "to": "assets/audio"
      },
      {
        "from": "assets/transcript",
        "to": "assets/transcript"
      },
      {
        "from": "assets/rss.csv",
        "to": "assets/rss.csv"
      }
    ],
    "afterPack": "./afterPack.cjs",
    "mac": {
      "icon": "./assets/app-icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.news",
      "additionalArguments": [
        "--no-strict"
      ],
      "strictVerify": false
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.59.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rss-parser": "^3.13.0"
  },
  "electronmon": {
    "patterns": [
      "!src/**/*",
      "!**/*.md",
      "!**/*.json",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/*.css",
      "!**/*.env",
      "!**/*.env.*"
    ],
    "logLevel": "quiet"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.2",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "wait-on": "^8.0.1"
  }
}
