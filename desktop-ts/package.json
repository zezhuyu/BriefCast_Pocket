{
  "name": "briefcast-desktop-ts",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript desktop rewrite for BriefCast",
  "main": "dist-electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:main": "tsup src/main/main.ts src/main/preload.ts --format cjs --external electron --out-dir dist-electron --watch",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173",
    "dev:electron": "wait-on dist-electron/main.cjs dist-electron/preload.cjs http-get://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 BRIEFCAST_ENABLE_API_BRIDGE=0 electronmon dist-electron/main.cjs",
    "dev:nextjs": "wait-on dist-electron/main.cjs dist-electron/preload.cjs http-get://127.0.0.1:3000 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:3000 BRIEFCAST_ENABLE_API_BRIDGE=1 electronmon dist-electron/main.cjs",
    "dev:with-nextjs": "concurrently -k \"npm:dev:main\" \"npm --prefix ../web run dev\" \"npm:dev:nextjs\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsup src/main/main.ts src/main/preload.ts --format cjs --external electron --out-dir dist-electron",
    "build:renderer": "vite build",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:dmg": "npm run build && electron-builder --mac dmg",
    "dist:dmg:unsigned": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "build": {
    "appId": "com.briefcast.desktopts",
    "productName": "BriefCast",
    "icon": "../backend/db/resources/bc2.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist-renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "mac": {
      "icon": "../backend/db/resources/bc2.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "category": "public.app-category.news"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rss-parser": "^3.13.0"
  },
  "electronmon": {
    "patterns": [
      "!src/**/*",
      "!**/*.md",
      "!**/*.json",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/*.css",
      "!**/*.env",
      "!**/*.env.*"
    ],
    "logLevel": "quiet"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^26.8.1",
    "electronmon": "^2.0.2",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
